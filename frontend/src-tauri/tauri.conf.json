{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IEDNavigator PRO",
  "version": "1.0.0",
  "identifier": "com.iednavigator.pro",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "IEDNavigator PRO",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 620,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Emilio Medina",
    "category": "Utility",
    "shortDescription": "Explorador y simulador IEC 61850",
    "longDescription": "Cliente y simulador IEC 61850: exploración MMS, control SBO/directo, Reports, GOOSE, Sampled Values y utilidades SCL.",
    "copyright": "© 2026 Emilio Medina",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/bridge": "bridge",
      "resources/runtime": "runtime"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installMode": "perMachine",
        "languages": ["Spanish", "English"],
        "displayLanguageSelector": true
      }
    }
  }
}
